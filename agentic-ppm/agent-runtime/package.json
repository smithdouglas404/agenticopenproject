{
  "name": "agentic-ppm-agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Grounding-service sidecar for Agentic PPM on OpenProject. OpenProject webhook -> projector -> FalkorDB/Graphiti -> detectors + rules -> findings/HITL inbox. No LLM reasoning (that lives in the Kyndral repo).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "seed:webhook": "tsx src/scripts/registerWebhook.ts",
    "sync:backfill": "tsx src/scripts/backfill.ts",
    "preflight": "tsx src/scripts/preflight.ts",
    "smoke": "tsx src/scripts/smoke.ts",
    "rules:eval": "tsx src/scripts/evaluateRules.ts",
    "rules:zen-smoke": "tsx src/scripts/zenSmoke.ts",
    "mapping:smoke": "tsx src/scripts/mappingSmoke.ts",
    "rules:suggest-smoke": "tsx src/scripts/suggestSmoke.ts"
  },
  "dependencies": {
    "@gorules/zen-engine": "^0.54.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "falkordb": "^6.2.7",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
