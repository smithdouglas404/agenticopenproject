{
  "name": "agentic-ppm-agent-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent-runtime sidecar for Agentic PPM on OpenProject. Quick slice: OpenProject webhook -> projector -> FalkorDB/Graphiti -> Insights & Risk agent -> Insights inbox.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "seed:webhook": "tsx src/scripts/registerWebhook.ts",
    "sync:backfill": "tsx src/scripts/backfill.ts",
    "preflight": "tsx src/scripts/preflight.ts",
    "smoke": "tsx src/scripts/smoke.ts",
    "letta:provision": "tsx src/scripts/provisionLetta.ts",
    "rules:eval": "tsx src/scripts/evaluateRules.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@letta-ai/letta-client": "^1.12.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "falkordb": "^6.2.7",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
