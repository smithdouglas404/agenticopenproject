# ---- Agent runtime ----
PORT=8745
LOG_LEVEL=info

# ---- OpenProject (source of truth) ----
# Base URL of the OpenProject instance, e.g. http://localhost:8080
OPENPROJECT_BASE_URL=http://localhost:8080
# API key from OpenProject account settings (sent as Basic apikey:<key>)
OPENPROJECT_API_KEY=
# Shared secret configured on the OpenProject webhook; used to verify X-OP-Signature (HMAC-SHA256)
OPENPROJECT_WEBHOOK_SECRET=
# Identifier of the project where Agent Alert (Insights inbox) work packages are created
OPENPROJECT_ALERTS_PROJECT=agent-alerts
# Marker written to agent-created work packages so webhooks can dedup our own changes
AGENT_SYNC_SOURCE=agentic-ppm

# ---- Claude API (Anthropic) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- FalkorDB (graph world-model) ----
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=agentic_ppm
# FALKORDB_PASSWORD=

# ---- Graphiti (temporal memory layer; seam not yet wired) ----
# GRAPHITI_URL=http://localhost:8000
