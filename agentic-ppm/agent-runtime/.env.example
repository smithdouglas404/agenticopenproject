# ---- Agent runtime ----
PORT=8745
LOG_LEVEL=info

# ---- OpenProject (source of truth) ----
# Base URL of the OpenProject instance, e.g. http://localhost:8080
OPENPROJECT_BASE_URL=http://localhost:8080
# API key from OpenProject account settings (sent as Basic apikey:<key>)
OPENPROJECT_API_KEY=
# Shared secret configured on the OpenProject webhook; used to verify X-OP-Signature (HMAC-SHA256)
OPENPROJECT_WEBHOOK_SECRET=
# Identifier of the project where Agent Alert (Insights inbox) work packages are created
OPENPROJECT_ALERTS_PROJECT=agent-alerts
# WP type used for Agent Alerts (defaults to Task, which exists on a stock instance)
OPENPROJECT_ALERT_TYPE=Task
# Marker written to agent-created work packages so webhooks can dedup our own changes
AGENT_SYNC_SOURCE=agentic-ppm
# Optional: custom-field API keys (e.g. customField12) — set ONLY if they exist on your instance
# OPENPROJECT_CF_SYNC_SOURCE=customField12
# OPENPROJECT_CF_ALERT_SEVERITY=customField13

# ---- Claude API (Anthropic) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- FalkorDB (graph world-model) ----
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=agentic_ppm
# FALKORDB_PASSWORD=

# ---- Graphiti (temporal memory, via its MCP server; layers on FalkorDB) ----
# Leave unset to run FalkorDB-only; the pipeline degrades gracefully.
# The current Graphiti MCP server (mcp-v1.0.2) uses HTTP transport at /mcp/.
# GRAPHITI_MCP_URL=http://graphiti-mcp-server.railway.internal:8000/mcp/
# Transport: http (streamable HTTP, current default) or sse (deprecated)
# GRAPHITI_MCP_TRANSPORT=http
# GRAPHITI_GROUP_ID=agentic_ppm
# GRAPHITI_ADD_MEMORY_TOOL=add_memory

# Log the full dependency preflight report at boot (set to 1 on Railway to
# verify OpenProject/FalkorDB/Graphiti wiring from the deploy logs).
# PREFLIGHT_ON_BOOT=1

# Backfill the graph from existing OpenProject data at boot (idempotent; runs in
# the background after the server is listening). Set to 1 for the first seed,
# then unset to avoid re-scanning OpenProject on every deploy.
# RUN_BACKFILL_ON_BOOT=1

# ---- Inference detectors & HITL Agent Console ----
# Periodic detector sweep interval in minutes (0 disables the schedule).
# DETECTOR_SWEEP_MINUTES=60
# Min minutes between event-triggered sweeps (webhook bursts won't hammer the graph).
# DETECTOR_EVENT_THROTTLE_MINUTES=10
# Publish new detector findings to OpenProject as Agent Alerts (0 = console-only).
# DETECTOR_PUBLISH=1
# Token guarding /console and /api when the sidecar has a public domain.
# Unset = open (private-network deployments). /health stays unguarded for Railway.
# CONSOLE_TOKEN=change-me
# Open work items per assignee before the Planning agent's CapacityOverload fires.
# CAPACITY_OVERLOAD_THRESHOLD=10
# Coalesce webhook bursts: seconds to wait per project before the LLM insight run.
# INSIGHT_DEBOUNCE_SECONDS=45
# Execute concrete actions on human approval (create follow-up task). 0 = comment-only.
# AGENT_ACTIONS=1
# WP type for agent-created follow-up tasks.
# AGENT_FOLLOWUP_TYPE=Task
# Write portfolio health (green/amber/red) to the OpenProject project status, so
# it shows as a colored banner on the project Overview page. 0 = off.
# AGENT_SET_PROJECT_STATUS=1
# OpenProject-native HITL: alert WP statuses that mean approve / reject the finding.
# ALERT_APPROVE_STATUSES=closed,resolved,approved,done
# ALERT_REJECT_STATUSES=rejected,cancelled,canceled
