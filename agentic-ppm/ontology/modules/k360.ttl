    rdfs:domain k360:Entity ;
    rdfs:range k360:Entity ;
    rdfs:label "caused by" ;
    rdfs:comment "Causal relationship for root cause analysis" ;
    owl:inverseOf k360:causes .

k360:causes a owl:ObjectProperty ;
    rdfs:domain k360:Entity ;
    rdfs:range k360:Entity ;
    rdfs:label "causes" .

