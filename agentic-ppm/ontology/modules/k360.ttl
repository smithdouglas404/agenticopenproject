k360:dependsOn a owl:ObjectProperty ;
    rdfs:domain safe:WorkItem ;
    rdfs:range safe:WorkItem ;
    rdfs:label "depends on" ;
    rdfs:comment "Work item dependency" .

k360:blockedBy a owl:ObjectProperty ;
