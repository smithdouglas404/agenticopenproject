@prefix k360: <https://kyndryl.com/k360/ontology#> .
@prefix safe: <https://scaledagileframework.com/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

# ═══════════════════════════════════════════════════════════════════════════════
# KYNDRYL FABRIC [K360] ENTERPRISE ONTOLOGY
# Version: 1.0
# Date: March 2026
# 
# This ontology integrates:
# - SAFe 6.0 Canonical Model (organizational hierarchy)
# - Nine autonomous agent domains (VRO, PMO, TMO, FinOps, OKR, Governance, Planning, OCM, Notification)
# - Temporal Knowledge Graph properties
# - Cross-domain relationships for agent reasoning
# ═══════════════════════════════════════════════════════════════════════════════

<https://kyndryl.com/k360/ontology> a owl:Ontology ;
    dc:title "Kyndryl Fabric K360 Enterprise Transformation Ontology" ;
    dc:description "AI-native governance ontology for multi-agent portfolio management" ;
    dc:creator "Kyndryl Architecture Team" ;
    owl:versionInfo "1.0" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1: FOUNDATIONAL CLASSES
# ═══════════════════════════════════════════════════════════════════════════════

# -----------------------------------------------------------------------------
# 1.1 Abstract Base Classes
# -----------------------------------------------------------------------------

k360:Entity a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Abstract base class for all K360 entities with temporal properties" .

k360:TemporalEntity a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Temporal Entity" ;
    rdfs:comment "Entity with valid_from, valid_to, and versioning support" .

k360:AuditableEntity a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Auditable Entity" ;
    rdfs:comment "Entity with full audit trail and change tracking" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2: SAFe 6.0 CORE HIERARCHY
# ═══════════════════════════════════════════════════════════════════════════════

# -----------------------------------------------------------------------------
# 2.1 Organizational Structure
# -----------------------------------------------------------------------------

safe:Portfolio a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Portfolio" ;
    rdfs:comment "Highest level of SAFe hierarchy. Contains value streams and strategic themes." ;
    skos:definition "A collection of value streams that deliver solutions to customers" .

safe:ValueStream a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Value Stream" ;
    rdfs:comment "Series of steps that deliver value to customers. Contains ARTs." ;
    skos:definition "The primary construct for understanding, organizing, and delivering value in SAFe" .

safe:ART a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Agile Release Train" ;
    rdfs:comment "Long-lived team of Agile teams that incrementally develops solutions." ;
    skos:altLabel "ART" .

safe:Team a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Team" ;
    rdfs:comment "Cross-functional group of 5-11 people responsible for defining, building, testing, and delivering value." .

safe:Division a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Division" ;
    rdfs:comment "Organizational unit grouping multiple portfolios or value streams." .

# -----------------------------------------------------------------------------
# 2.2 Work Item Hierarchy
# -----------------------------------------------------------------------------

safe:WorkItem a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Work Item" ;
    rdfs:comment "Abstract base class for all work items in the SAFe hierarchy" .

safe:StrategicTheme a owl:Class ;
    rdfs:subClassOf safe:WorkItem ;
    rdfs:label "Strategic Theme" ;
    rdfs:comment "Business objective that connects portfolio to enterprise strategy" .

safe:Epic a owl:Class ;
    rdfs:subClassOf safe:WorkItem ;
    rdfs:label "Epic" ;
    rdfs:comment "Large initiative that spans multiple PIs. Requires Lean business case." ;
    skos:definition "A container for a significant Solution development initiative" .

safe:Feature a owl:Class ;
    rdfs:subClassOf safe:WorkItem ;
    rdfs:label "Feature" ;
    rdfs:comment "Benefit-driven functionality that delivers value to users." .

safe:Story a owl:Class ;
    rdfs:subClassOf safe:WorkItem ;
    rdfs:label "Story" ;
    rdfs:comment "Short description of a small piece of desired functionality from user perspective." ;
    skos:altLabel "User Story" .

safe:Task a owl:Class ;
    rdfs:subClassOf safe:WorkItem ;
    rdfs:label "Task" ;
    rdfs:comment "Small unit of work needed to complete a story. Typically hours of effort." .

safe:Enabler a owl:Class ;
    rdfs:subClassOf safe:WorkItem ;
    rdfs:label "Enabler" ;
    rdfs:comment "Technical work that supports future business functionality." .

# -----------------------------------------------------------------------------
# 2.3 Planning Constructs
# -----------------------------------------------------------------------------

safe:ProgramIncrement a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Program Increment" ;
    rdfs:comment "8-12 week timebox during which an ART delivers incremental value." ;
    skos:altLabel "PI" .

safe:Sprint a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Sprint" ;
    rdfs:comment "2-week iteration within a PI where teams deliver working software." ;
    skos:altLabel "Iteration" .

safe:Milestone a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Milestone" ;
    rdfs:comment "Significant event or checkpoint in the delivery timeline." .

safe:Dependency a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Dependency" ;
    rdfs:comment "Relationship where one work item depends on completion of another." .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3: VRO AGENT DOMAIN (Value Realization Office)
# ═══════════════════════════════════════════════════════════════════════════════

k360:Investment a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Investment" ;
    rdfs:comment "Financial commitment to a portfolio initiative with expected returns." ;
    skos:definition "VRO Agent: Tracks capital allocation, ROI projections, and benefit realization" .

k360:Benefit a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Benefit" ;
    rdfs:comment "Quantifiable value delivered by an investment or initiative." .

k360:BenefitRealization a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Benefit Realization" ;
    rdfs:comment "Tracking record of actual benefits delivered against planned benefits." .

k360:ValueMetric a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Value Metric" ;
    rdfs:comment "KPI used to measure value delivery (ROI, NPV, IRR, payback period)." .

k360:InvestmentPortfolio a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Investment Portfolio" ;
    rdfs:comment "Collection of investments managed as a unit for diversification and risk management." .

# VRO-specific data properties
k360:roi a owl:DatatypeProperty ;
    rdfs:domain k360:Investment ;
    rdfs:range xsd:decimal ;
    rdfs:label "ROI" ;
    rdfs:comment "Return on Investment as decimal (0.15 = 15%)" .

k360:npv a owl:DatatypeProperty ;
    rdfs:domain k360:Investment ;
    rdfs:range xsd:decimal ;
    rdfs:label "NPV" ;
    rdfs:comment "Net Present Value in portfolio currency" .

k360:irr a owl:DatatypeProperty ;
    rdfs:domain k360:Investment ;
    rdfs:range xsd:decimal ;
    rdfs:label "IRR" ;
    rdfs:comment "Internal Rate of Return as decimal" .

k360:paybackPeriod a owl:DatatypeProperty ;
    rdfs:domain k360:Investment ;
    rdfs:range xsd:integer ;
    rdfs:label "Payback Period" ;
    rdfs:comment "Months until investment breaks even" .

k360:benefitTarget a owl:DatatypeProperty ;
    rdfs:domain k360:Benefit ;
    rdfs:range xsd:decimal ;
    rdfs:label "Benefit Target" ;
    rdfs:comment "Planned benefit amount" .

k360:benefitActual a owl:DatatypeProperty ;
    rdfs:domain k360:BenefitRealization ;
    rdfs:range xsd:decimal ;
    rdfs:label "Benefit Actual" ;
    rdfs:comment "Realized benefit amount" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 4: STRATEGIC PMO AGENT DOMAIN (Portfolio Delivery)
# ═══════════════════════════════════════════════════════════════════════════════

k360:Project a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Project" ;
    rdfs:comment "Time-bounded initiative with defined scope, budget, and deliverables." ;
    skos:definition "PMO Agent: Tracks delivery status, flow metrics, and schedule performance" .

k360:Program a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Program" ;
    rdfs:comment "Collection of related projects managed together for coordinated benefits." .

k360:FlowMetric a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Flow Metric" ;
    rdfs:comment "SAFe flow measurement: Distribution, Velocity, Time, Load, Efficiency, Predictability." .

k360:ScheduleVariance a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Schedule Variance" ;
    rdfs:comment "Difference between planned and actual schedule performance." .

k360:ResourceAllocation a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Resource Allocation" ;
    rdfs:comment "Assignment of resources to projects or teams over time." .

k360:DeliveryRisk a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Delivery Risk" ;
    rdfs:comment "Risk specifically related to schedule, scope, or resource delivery." .

# PMO-specific data properties
k360:projectStatus a owl:DatatypeProperty ;
    rdfs:domain k360:Project ;
    rdfs:range xsd:string ;
    rdfs:label "Project Status" ;
    rdfs:comment "RAG status: Red, Amber, Green" .

k360:percentComplete a owl:DatatypeProperty ;
    rdfs:domain k360:Project ;
    rdfs:range xsd:decimal ;
    rdfs:label "Percent Complete" ;
    rdfs:comment "Completion percentage (0.0 to 1.0)" .

k360:cycleTime a owl:DatatypeProperty ;
    rdfs:domain k360:FlowMetric ;
    rdfs:range xsd:decimal ;
    rdfs:label "Cycle Time" ;
    rdfs:comment "Average time from work start to completion (days)" .

k360:throughput a owl:DatatypeProperty ;
    rdfs:domain k360:FlowMetric ;
    rdfs:range xsd:integer ;
    rdfs:label "Throughput" ;
    rdfs:comment "Number of items completed per time period" .

k360:wip a owl:DatatypeProperty ;
    rdfs:domain k360:FlowMetric ;
    rdfs:range xsd:integer ;
    rdfs:label "WIP" ;
    rdfs:comment "Work in Progress count" .

k360:flowEfficiency a owl:DatatypeProperty ;
    rdfs:domain k360:FlowMetric ;
    rdfs:range xsd:decimal ;
    rdfs:label "Flow Efficiency" ;
    rdfs:comment "Active time / Total time ratio" .

k360:spi a owl:DatatypeProperty ;
    rdfs:domain k360:ScheduleVariance ;
    rdfs:range xsd:decimal ;
    rdfs:label "SPI" ;
    rdfs:comment "Schedule Performance Index (EV/PV)" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 5: TMO AGENT DOMAIN (Transformation Management Office)
# ═══════════════════════════════════════════════════════════════════════════════

k360:TransformationProgram a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Transformation Program" ;
    rdfs:comment "Large-scale organizational change initiative spanning multiple projects." ;
    skos:definition "TMO Agent: Tracks transformation progress, adoption, and business outcomes" .

k360:Initiative a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Initiative" ;
    rdfs:comment "Specific workstream within a transformation program." .

k360:AdoptionMetric a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Adoption Metric" ;
    rdfs:comment "Measurement of how well changes are being adopted by the organization." .

k360:TransformationFatigue a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Transformation Fatigue" ;
    rdfs:comment "Indicator that change velocity is overwhelming the organization." .

k360:BusinessOutcome a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Business Outcome" ;
    rdfs:comment "Measurable business result linked to transformation initiatives." .

# TMO-specific data properties
k360:adoptionRate a owl:DatatypeProperty ;
    rdfs:domain k360:AdoptionMetric ;
    rdfs:range xsd:decimal ;
    rdfs:label "Adoption Rate" ;
    rdfs:comment "Percentage of target audience that has adopted the change" .

k360:adoptionTarget a owl:DatatypeProperty ;
    rdfs:domain k360:AdoptionMetric ;
    rdfs:range xsd:decimal ;
    rdfs:label "Adoption Target" ;
    rdfs:comment "Target adoption percentage" .

k360:adoptionVelocity a owl:DatatypeProperty ;
    rdfs:domain k360:AdoptionMetric ;
    rdfs:range xsd:decimal ;
    rdfs:label "Adoption Velocity" ;
    rdfs:comment "Rate of change in adoption (delta per period)" .

k360:fatigueScore a owl:DatatypeProperty ;
    rdfs:domain k360:TransformationFatigue ;
    rdfs:range xsd:decimal ;
    rdfs:label "Fatigue Score" ;
    rdfs:comment "0-1 score indicating transformation fatigue level" .

k360:outcomeValue a owl:DatatypeProperty ;
    rdfs:domain k360:BusinessOutcome ;
    rdfs:range xsd:decimal ;
    rdfs:label "Outcome Value" ;
    rdfs:comment "Quantified business outcome value" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 6: FINOPS AGENT DOMAIN (Financial Operations)
# ═══════════════════════════════════════════════════════════════════════════════

k360:Budget a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Budget" ;
    rdfs:comment "Allocated financial resources for a project, program, or portfolio." ;
    skos:definition "FinOps Agent: Tracks budget allocation, spend, and forecasts" .

k360:CostRecord a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Cost Record" ;
    rdfs:comment "Individual cost transaction or accrual." .

k360:Forecast a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Forecast" ;
    rdfs:comment "Projected future spending based on current burn rate and trends." .

k360:CostAnomaly a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Cost Anomaly" ;
    rdfs:comment "Detected deviation from expected cost patterns." .

k360:CostOptimization a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Cost Optimization" ;
    rdfs:comment "Recommended action to reduce costs or improve cost efficiency." .

k360:SpendCategory a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Spend Category" ;
    rdfs:comment "Classification of costs (labor, infrastructure, vendor, etc.)" .

# FinOps-specific data properties
k360:budgetAmount a owl:DatatypeProperty ;
    rdfs:domain k360:Budget ;
    rdfs:range xsd:decimal ;
    rdfs:label "Budget Amount" ;
    rdfs:comment "Total allocated budget" .

k360:budgetUtilization a owl:DatatypeProperty ;
    rdfs:domain k360:Budget ;
    rdfs:range xsd:decimal ;
    rdfs:label "Budget Utilization" ;
    rdfs:comment "Percentage of budget spent (0-1)" .

k360:actualSpend a owl:DatatypeProperty ;
    rdfs:domain k360:Budget ;
    rdfs:range xsd:decimal ;
    rdfs:label "Actual Spend" ;
    rdfs:comment "Cumulative actual spending" .

k360:burnRate a owl:DatatypeProperty ;
    rdfs:domain k360:Forecast ;
    rdfs:range xsd:decimal ;
    rdfs:label "Burn Rate" ;
    rdfs:comment "Current spending rate per period" .

k360:cpi a owl:DatatypeProperty ;
    rdfs:domain k360:Budget ;
    rdfs:range xsd:decimal ;
    rdfs:label "CPI" ;
    rdfs:comment "Cost Performance Index (EV/AC)" .

k360:eac a owl:DatatypeProperty ;
    rdfs:domain k360:Forecast ;
    rdfs:range xsd:decimal ;
    rdfs:label "EAC" ;
    rdfs:comment "Estimate at Completion" .

k360:costAmount a owl:DatatypeProperty ;
    rdfs:domain k360:CostRecord ;
    rdfs:range xsd:decimal ;
    rdfs:label "Cost Amount" ;
    rdfs:comment "Individual cost transaction amount" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 7: OKR AGENT DOMAIN (Strategy Execution)
# ═══════════════════════════════════════════════════════════════════════════════

k360:OKR a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "OKR" ;
    rdfs:comment "Objectives and Key Results - strategic goal-setting framework." ;
    skos:definition "OKR Agent: Tracks strategic alignment from company to project level" .

k360:Objective a owl:Class ;
    rdfs:subClassOf k360:OKR ;
    rdfs:label "Objective" ;
    rdfs:comment "Qualitative, inspirational goal that defines what you want to achieve." .

k360:KeyResult a owl:Class ;
    rdfs:subClassOf k360:OKR ;
    rdfs:label "Key Result" ;
    rdfs:comment "Quantitative metric that measures progress toward an Objective." .

k360:AlignmentScore a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Alignment Score" ;
    rdfs:comment "Calculated measure of how well work aligns to strategic objectives." .

k360:OrphanedProject a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Orphaned Project" ;
    rdfs:comment "Project not linked to any OKR or strategic objective." .

k360:OKRCascade a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "OKR Cascade" ;
    rdfs:comment "Hierarchical alignment from company OKRs to division to team." .

# OKR-specific data properties
k360:objectiveText a owl:DatatypeProperty ;
    rdfs:domain k360:Objective ;
    rdfs:range xsd:string ;
    rdfs:label "Objective Text" ;
    rdfs:comment "The qualitative objective statement" .

k360:keyResultTarget a owl:DatatypeProperty ;
    rdfs:domain k360:KeyResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "Key Result Target" ;
    rdfs:comment "Target value for the key result" .

k360:keyResultActual a owl:DatatypeProperty ;
    rdfs:domain k360:KeyResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "Key Result Actual" ;
    rdfs:comment "Current actual value" .

k360:keyResultProgress a owl:DatatypeProperty ;
    rdfs:domain k360:KeyResult ;
    rdfs:range xsd:decimal ;
    rdfs:label "Key Result Progress" ;
    rdfs:comment "Progress percentage (0-1)" .

k360:alignmentScoreValue a owl:DatatypeProperty ;
    rdfs:domain k360:AlignmentScore ;
    rdfs:range xsd:decimal ;
    rdfs:label "Alignment Score Value" ;
    rdfs:comment "Calculated alignment score (0-1)" .

k360:okrQuarter a owl:DatatypeProperty ;
    rdfs:domain k360:OKR ;
    rdfs:range xsd:string ;
    rdfs:label "OKR Quarter" ;
    rdfs:comment "Quarter for this OKR cycle (Q1, Q2, Q3, Q4)" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 8: GOVERNANCE AGENT DOMAIN (Compliance & Risk)
# ═══════════════════════════════════════════════════════════════════════════════

k360:Policy a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Policy" ;
    rdfs:comment "Governance rule or standard that must be followed." ;
    skos:definition "Governance Agent: Executable policy-as-code with temporal versioning" .

k360:PolicyRule a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Policy Rule" ;
    rdfs:comment "Individual executable rule within a policy (GoRules decision table)." .

k360:ComplianceCheckpoint a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Compliance Checkpoint" ;
    rdfs:comment "Point-in-time compliance assessment for an entity." .

k360:ComplianceViolation a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Compliance Violation" ;
    rdfs:comment "Detected non-compliance with a policy or rule." .

k360:AuditTrail a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Audit Trail" ;
    rdfs:comment "Record of significant actions and decisions for audit purposes." .

k360:Risk a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Risk" ;
    rdfs:comment "Identified uncertainty that could impact objectives." .

k360:RiskMitigation a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Risk Mitigation" ;
    rdfs:comment "Action taken to reduce risk probability or impact." .

k360:RegulatoryFramework a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Regulatory Framework" ;
    rdfs:comment "External regulatory requirements (SOX, GDPR, SOC2, etc.)" .

# Governance-specific data properties
k360:policyStatus a owl:DatatypeProperty ;
    rdfs:domain k360:Policy ;
    rdfs:range xsd:string ;
    rdfs:label "Policy Status" ;
    rdfs:comment "Active, Draft, Deprecated, Superseded" .

k360:policyType a owl:DatatypeProperty ;
    rdfs:domain k360:Policy ;
    rdfs:range xsd:string ;
    rdfs:label "Policy Type" ;
    rdfs:comment "Threshold, Behavioral, Workflow, Compliance" .

k360:complianceStatus a owl:DatatypeProperty ;
    rdfs:domain k360:ComplianceCheckpoint ;
    rdfs:range xsd:string ;
    rdfs:label "Compliance Status" ;
    rdfs:comment "Compliant, Non-Compliant, Pending Review" .

k360:riskSeverity a owl:DatatypeProperty ;
    rdfs:domain k360:Risk ;
    rdfs:range xsd:decimal ;
    rdfs:label "Risk Severity" ;
    rdfs:comment "Combined probability × impact score (0-1)" .

k360:riskProbability a owl:DatatypeProperty ;
    rdfs:domain k360:Risk ;
    rdfs:range xsd:decimal ;
    rdfs:label "Risk Probability" ;
    rdfs:comment "Likelihood of risk occurring (0-1)" .

k360:riskImpact a owl:DatatypeProperty ;
    rdfs:domain k360:Risk ;
    rdfs:range xsd:decimal ;
    rdfs:label "Risk Impact" ;
    rdfs:comment "Severity if risk occurs (0-1)" .

k360:riskStatus a owl:DatatypeProperty ;
    rdfs:domain k360:Risk ;
    rdfs:range xsd:string ;
    rdfs:label "Risk Status" ;
    rdfs:comment "Open, Mitigated, Closed, Accepted" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 9: PLANNING AGENT DOMAIN (Capacity & Roadmap)
# ═══════════════════════════════════════════════════════════════════════════════

k360:CapacityPlan a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Capacity Plan" ;
    rdfs:comment "Resource availability and allocation plan for a time period." ;
    skos:definition "Planning Agent: Forecasts capacity, dependencies, and roadmap scenarios" .

k360:Resource a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Resource" ;
    rdfs:comment "Person, team, or asset that can be allocated to work." .

k360:Roadmap a owl:Class ;
    rdfs:subClassOf k360:AuditableEntity ;
    rdfs:label "Roadmap" ;
    rdfs:comment "Visual timeline of planned initiatives and milestones." .

k360:Scenario a owl:Class ;
    rdfs:subClassOf k360:Entity ;
    rdfs:label "Scenario" ;
    rdfs:comment "What-if simulation for planning decisions." .

k360:DependencyAnalysis a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Dependency Analysis" ;
    rdfs:comment "Cross-project dependency mapping and critical path identification." .

k360:CapacityForecast a owl:Class ;
    rdfs:subClassOf k360:TemporalEntity ;
    rdfs:label "Capacity Forecast" ;
    rdfs:comment "Projected resource availability and demand." .

# Planning-specific data properties
k360:totalCapacity a owl:DatatypeProperty ;
    rdfs:domain k360:CapacityPlan ;
    rdfs:range xsd:decimal ;
    rdfs:label "Total Capacity" ;
    rdfs:comment "Total available capacity (FTEs or hours)" .

k360:allocatedCapacity a owl:DatatypeProperty ;
    rdfs:domain k360:CapacityPlan ;
    rdfs:range xsd:decimal ;
    rdfs:label "Allocated Capacity" ;
    rdfs:comment "Capacity committed to work items" .

k360:availableCapacity a owl:DatatypeProperty ;
    rdfs:domain k360:CapacityPlan ;
    rdfs:range xsd:decimal ;
