    rdfs:range safe:WorkItem ;
    rdfs:label "blocked by" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 15: AXIOMS AND CONSTRAINTS
# ═══════════════════════════════════════════════════════════════════════════════

# -----------------------------------------------------------------------------
# 15.1 Cardinality Constraints
# -----------------------------------------------------------------------------

# Every Epic MUST align to at least one OKR
safe:Epic rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty k360:alignsTo ;
    owl:minCardinality 1
] .

# Every Project MUST have exactly one Budget
k360:Project rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty k360:hasBudget ;
    owl:cardinality 1
] .

# Every Key Result belongs to exactly one Objective
k360:KeyResult rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty [ owl:inverseOf k360:hasKeyResult ] ;
    owl:cardinality 1
] .

# -----------------------------------------------------------------------------
# 15.2 Critical Risk Constraint
# High-severity risks require at least one mitigation
# -----------------------------------------------------------------------------

k360:CriticalRisk a owl:Class ;
    owl:equivalentClass [
        owl:intersectionOf (
            k360:Risk
            [ a owl:Restriction ;
              owl:onProperty k360:riskSeverity ;
              owl:someValuesFrom [
                  a rdfs:Datatype ;
                  owl:onDatatype xsd:decimal ;
                  owl:withRestrictions (
                      [ xsd:minInclusive "0.8"^^xsd:decimal ]
                  )
              ]
            ]
        )
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty k360:mitigatedBy ;
        owl:minCardinality 1
    ] .

# -----------------------------------------------------------------------------
# 15.3 Budget Threshold Constraints
# -----------------------------------------------------------------------------

k360:OverBudgetProject a owl:Class ;
    owl:equivalentClass [
        owl:intersectionOf (
            k360:Project
            [ a owl:Restriction ;
              owl:onProperty k360:hasBudget ;
              owl:someValuesFrom [
                  owl:intersectionOf (
                      k360:Budget
                      [ a owl:Restriction ;
                        owl:onProperty k360:budgetUtilization ;
                        owl:someValuesFrom [
                            a rdfs:Datatype ;
                            owl:onDatatype xsd:decimal ;
                            owl:withRestrictions (
                                [ xsd:minExclusive "1.0"^^xsd:decimal ]
                            )
                        ]
                      ]
                  )
              ]
            ]
        )
    ] .

# -----------------------------------------------------------------------------
# 15.4 Temporal Constraints
# supersedes implies valid_to of superseded <= valid_from of new
# -----------------------------------------------------------------------------

# This is expressed as SHACL in practice, but documented here for the model:
# CONSTRAINT: If Policy A supersedes Policy B, then B.valid_to <= A.valid_from

# -----------------------------------------------------------------------------
# 15.5 Low Readiness Constraint
# Low readiness initiatives should have adoption barriers identified
# -----------------------------------------------------------------------------

k360:LowReadinessInitiative a owl:Class ;
    owl:equivalentClass [
        owl:intersectionOf (
            k360:Initiative
            [ a owl:Restriction ;
              owl:onProperty k360:hasReadinessAssessment ;
              owl:someValuesFrom [
                  owl:intersectionOf (
                      k360:ReadinessAssessment
                      [ a owl:Restriction ;
                        owl:onProperty k360:readinessScore ;
                        owl:someValuesFrom [
                            a rdfs:Datatype ;
                            owl:onDatatype xsd:decimal ;
                            owl:withRestrictions (
                                [ xsd:maxInclusive "0.5"^^xsd:decimal ]
                            )
                        ]
                      ]
                  )
              ]
            ]
        )
    ] .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 16: INFERENCE RULES (For Agent Reasoning)
# ═══════════════════════════════════════════════════════════════════════════════

# These are documented as SWRL-style rules for implementation in Timbr.ai or Stardog

# RULE 1: Orphaned Project Detection
# IF Project NOT alignsTo any OKR THEN classify as OrphanedProject

# RULE 2: Budget Alert Trigger
# IF Budget.budgetUtilization > 0.9 AND Project.percentComplete < 0.7
# THEN generate Alert with priority=High

# RULE 3: Transformation Fatigue Detection  
# IF Division has > 3 Initiatives with AdoptionMetric.adoptionVelocity < 0
# THEN create TransformationFatigue for Division

# RULE 4: Cross-Agent Collaboration Trigger
# IF Risk.riskSeverity > 0.7 AND Risk correlatesWith ScheduleVariance
# THEN initiate A2AConversation between Governance and PMO agents

# RULE 5: Compliance Violation Auto-Detection
# IF Project governedBy Policy AND ComplianceCheckpoint.status = "Non-Compliant"
# THEN create ComplianceViolation AND generate Alert

# RULE 6: Benefit Realization Gap
# IF BenefitRealization.benefitActual < (Benefit.benefitTarget * 0.8) 
#    AND Investment.valid_to HAS PASSED
# THEN Alert VRO Agent with priority=High

# RULE 7: Capacity Over-allocation
# IF CapacityPlan.allocatedCapacity > CapacityPlan.totalCapacity
# THEN Alert Planning Agent AND flag CapacityPlan as "Over-allocated"

# RULE 8: Policy Staleness Detection
# IF Policy.updated_at < (NOW - 365 days) AND Policy.status = "Active"
# THEN Alert Governance Agent for policy review


# ═══════════════════════════════════════════════════════════════════════════════
# END OF ONTOLOGY
