# -----------------------------------------------------------------------------
# 14.1 SAFe Hierarchy Relationships
# -----------------------------------------------------------------------------

safe6:containsValueStream a owl:ObjectProperty ;
    rdfs:domain safe6:Portfolio ;
    rdfs:range safe6:ValueStream ;
    rdfs:label "contains value stream" ;
    owl:inverseOf safe6:belongsToPortfolio .

safe6:belongsToPortfolio a owl:ObjectProperty ;
    rdfs:domain safe6:ValueStream ;
    rdfs:range safe6:Portfolio ;
    rdfs:label "belongs to portfolio" .

safe6:containsART a owl:ObjectProperty ;
    rdfs:domain safe6:ValueStream ;
    rdfs:range safe6:ART ;
    rdfs:label "contains ART" .

safe6:containsTeam a owl:ObjectProperty ;
    rdfs:domain safe6:ART ;
    rdfs:range safe6:Team ;
    rdfs:label "contains team" .

safe6:decomposesTo a owl:ObjectProperty ;
    rdfs:domain safe6:WorkItem ;
    rdfs:range safe6:WorkItem ;
    rdfs:label "decomposes to" ;
    rdfs:comment "Epic → Feature → Story → Task" .

safe6:belongsToPI a owl:ObjectProperty ;
    rdfs:domain safe6:WorkItem ;
    rdfs:range safe6:ProgramIncrement ;
    rdfs:label "belongs to PI" .

safe6:belongsToSprint a owl:ObjectProperty ;
    rdfs:domain safe6:Story ;
    rdfs:range safe6:Sprint ;
    rdfs:label "belongs to sprint" .

# -----------------------------------------------------------------------------
# 14.2 VRO Relationships
# -----------------------------------------------------------------------------

k360:hasInvestment a owl:ObjectProperty ;
    rdfs:domain safe6:Epic ;
    rdfs:range k360:Investment ;
