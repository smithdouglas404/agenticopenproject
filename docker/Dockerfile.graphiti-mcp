# Graphiti MCP server — Railway-compatible build.
#
# The upstream getzep/graphiti Dockerfiles use --mount=type=cache (BuildKit
# cache mounts) which Railway's builder does not support. This file achieves
# the same result using plain RUN layers that work on any standard Docker
# daemon.
#
# Runtime requirements:
#   NEO4J_URI          bolt://neo4j:7687
#   NEO4J_USER         neo4j
#   NEO4J_PASSWORD     <secret>
#   ANTHROPIC_API_KEY  <secret>   (LLM)
#   OPENAI_API_KEY     <secret>   (embeddings)
#   PORT               8000       (HTTP / SSE transport)

FROM python:3.11-slim-bookworm

# ── System dependencies ────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        git \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Install uv (no cache-mount syntax) ────────────────────────────────────────
# Pin to a known-good release so builds are reproducible.
ENV UV_VERSION=0.4.30
RUN curl -fsSL https://astral.sh/uv/install.sh | UV_INSTALL_DIR=/usr/local/bin sh \
    && uv --version

# ── Clone graphiti source ──────────────────────────────────────────────────────
# Shallow clone keeps the image small; pin to a stable tag when available.
ARG GRAPHITI_REF=main
RUN git clone --depth 1 --branch ${GRAPHITI_REF} \
        https://github.com/getzep/graphiti.git /opt/graphiti

WORKDIR /opt/graphiti/mcp_server

# ── Install Python dependencies ────────────────────────────────────────────────
# UV_NO_CACHE avoids writing a cache directory that would bloat the layer.
RUN UV_NO_CACHE=1 uv sync --no-dev

# ── Runtime environment defaults ───────────────────────────────────────────────
# These are overridden at deploy time via Railway service variables / secrets.
ENV NEO4J_URI=bolt://neo4j:7687 \
    NEO4J_USER=neo4j \
    NEO4J_PASSWORD="" \
    ANTHROPIC_API_KEY="" \
    OPENAI_API_KEY="" \
    PORT=8000

EXPOSE 8000

# ── Health check ───────────────────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# ── Start ──────────────────────────────────────────────────────────────────────
CMD ["uv", "run", "server.py"]
