<%= component_wrapper(
      class: "op-meeting-presentation",
      data: {
        controller: "meetings--presentation poll-for-changes",
        poll_for_changes_continuous_value: true,
        poll_for_changes_url_value: check_for_updates_project_meeting_presentation_path(
          @meeting.project,
          @meeting,
          meeting_agenda_item_id: current_item.id
        ),
        poll_for_changes_interval_value: check_for_updates_interval,
      }
  ) do %>
  <%=
    render Primer::OpenProject::PageHeader.new(classes: "op-meeting-presentation-header") do |header|
      header.with_breadcrumbs([])
      header.with_title_content(@meeting.title)

      header.with_action_button(
        tag: :a,
        scheme: :invisible,
        mobile_icon: :x,
        mobile_label: t(:"meeting.presentation_mode.exit"),
        href: meeting_path(@meeting),
        aria: { label: t(:"meeting.presentation_mode.exit") },
        title: t(:"meeting.presentation_mode.exit"),
      ) do |button|
        button.with_leading_visual_icon(icon: :x)
        t(:"meeting.presentation_mode.exit")
      end
    end
  %>
  <%= content_tag :div,
                  id: "op-meeting-presentation-content",
                  class: "op-meeting-presentation--content",
                  data: {
                    controller: "meetings--submit",
                    poll_for_changes_target: "reference",
                    reference_value: current_item.updated_at.iso8601
                  } do %>
    <%= render(border_box_container) do |container| %>
      <%= render MeetingAgendaItems::ItemComponent.new(
        container:,
        meeting_agenda_item: current_item,
        presentation_mode: true
      ) %>
    <% end %>
  <% end %>

  <!-- Footer with controls -->
  <div class="op-meeting-presentation--footer">
    <div class="op-meeting-presentation--footer-left">
      <%= render(Primer::Beta::Button.new(
        tag: :a,
        scheme: :link,
        href: project_meeting_presentation_path(@project, @meeting, current_id: previous_id),
        data: { "meetings--presentation-target": "previousButton" },
        disabled: !has_previous?
      )) do |button| %>
        <% button.with_leading_visual_icon(icon: :"chevron-left") %>
        <%= t('meeting.presentation_mode.previous') %>
      <% end %>
    </div>

    <div class="op-meeting-presentation--progress">
      <%= progress_text %>
    </div>

    <div class="op-meeting-presentation--footer-right">
      <%= render(Primer::Beta::Button.new(
        tag: :a,
        scheme: :link,
        href: project_meeting_presentation_path(@project, @meeting, current_id: next_id),
        data: { "meetings--presentation-target": "nextButton" },
        disabled: !has_next?
      )) do |button| %>
        <%= t('meeting.presentation_mode.next') %>
        <% button.with_trailing_visual_icon(icon: :"chevron-right") %>
      <% end %>
    </div>
  </div>
<% end %>
