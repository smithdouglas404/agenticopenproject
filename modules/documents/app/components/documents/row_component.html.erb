<%=
  grid_layout("op-documents-list--row", tag: :div, align_items: :center) do |grid|
    grid.with_area(:name, tag: :div, mr: 3, classes: "ellipsis") do
      render(
        Primer::Beta::Link.new(
          href: url_helpers.url_for({ controller: "/documents", action: "show", id: document }),
          font_weight: :bold,
          mr: 1,
          data: { test_selector: "document-name" }
        )
      ) do
        document.title
      end
    end

    if document.type.present?
      grid.with_area(:type, tag: :div, color: :subtle, mr: 3, hide: :sm, data: { test_selector: "document-type" }) do
        render(Primer::Beta::Truncate.new(font_weight: :normal)) { document.type.name }
      end
    end

    grid.with_area(:updated_at, tag: :div, color: :subtle) do
      render(Primer::Beta::Text.new(font_weight: :light)) { updated_at_time(document) }
    end
  end
%>
