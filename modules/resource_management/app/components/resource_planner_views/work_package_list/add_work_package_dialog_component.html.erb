<%=
  render(
    Primer::Alpha::Dialog.new(
      id: DIALOG_ID,
      title:,
      size: :medium_portrait
    )
  ) do |dialog|
    dialog.with_header(variant: :large)

    # Gives the autocompleter dropdown room in this content-sized modal — the
    # shared fix for autocompleters in centered dialogs.
    dialog.with_body(classes: "Overlay-body_autocomplete_height") do
      primer_form_with(
        url: form_url,
        method: :post,
        html: { data: { turbo_stream: true }, id: FORM_ID }
      ) do |f|
        render(
          ResourcePlannerViews::WorkPackageList::AddWorkPackageForm.new(
            f,
            project: @project,
            append_to: DIALOG_ID,
            excluded_ids: already_added_work_package_ids
          )
        )
      end
    end

    dialog.with_footer do
      render(
        Primer::Beta::Button.new(type: :submit, form: FORM_ID, scheme: :primary)
      ) { I18n.t(:button_add) }
    end
  end
%>
