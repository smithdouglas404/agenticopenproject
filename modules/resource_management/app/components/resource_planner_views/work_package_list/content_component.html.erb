<%= render(
      ResourcePlannerViews::WorkPackageList::SubHeaderComponent.new(
        project: @project,
        resource_planner: @resource_planner,
        view: @view
      )
    ) %>
<%
  table = ResourcePlannerViews::WorkPackageList::TableComponent.new(
    rows: work_packages,
    view: @view,
    project: @project,
    resource_planner: @resource_planner
  )
%>
<% if @view.manually_picked? %>
  <%# `target-container-accessor` selects the body rowgroup (the header one
      carries .Box-header); the BorderBox markup offers no hook on the list
      element itself. %>
  <%= content_tag(
        :div,
        data: { controller: "generic-drag-and-drop", "generic-drag-and-drop-position-mode-value": "position" }
      ) do %>
    <%= content_tag(
          :div,
          data: {
            "generic-drag-and-drop-target": "container",
            "target-container-accessor": "[role=rowgroup]:not(.Box-header)",
            "target-allowed-drag-type": ResourcePlannerViews::WorkPackageList::RowComponent::DRAGGABLE_TYPE
          }
        ) do %>
      <%= render(table) %>
    <% end %>
  <% end %>
<% else %>
  <%= render(table) %>
<% end %>
