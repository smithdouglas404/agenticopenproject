<%=
  render(
    Primer::Alpha::Dialog.new(
      title:,
      size: :large,
      classes: "Overlay--size-large-portrait",
      id: DIALOG_ID,
      data: { "keep-open-on-submit": true }
    )
  ) do |d|
    d.with_header(variant: :large)

    d.with_body do
      render(
        ResourcePlanners::FormComponent.new(
          resource_planner: @resource_planner,
          project: @project
        )
      )
    end

    d.with_footer do
      render(ResourcePlanners::FooterComponent.new)
    end
  end
%>
