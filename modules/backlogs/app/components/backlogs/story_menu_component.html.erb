<%# The menu's items (Open details, Open fullscreen, divider, four
    Move-to actions) are rendered server-side by RbStoriesController#menu
    and fetched on first hover/click via Primer ActionMenu's `src:` mode.
    Eagerly rendering all those items inline blew up initial-render CPU
    on backlogs pages with hundreds of rows; deferring means the inline
    DOM is just the kebab trigger and an include-fragment placeholder. %>
<%=
  render(
    Primer::Alpha::ActionMenu.new(
      menu_id: dom_id(story),
      src: menu_backlogs_project_sprint_story_path(project, sprint, story),
      preload: true,
      anchor_align: :end,
      classes: "hide-when-print"
    )
  ) do |menu|
    menu.with_show_button(
      scheme: :invisible,
      icon: :"kebab-horizontal",
      "aria-label": t(".label_actions"),
      tooltip_direction: :se
    )
  end
%>
