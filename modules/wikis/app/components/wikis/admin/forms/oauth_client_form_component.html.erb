<%=
  component_wrapper do
    primer_form_with(
      model: resolved_oauth_client,
      url: form_url,
      method: form_method
    ) do |form|
      flex_layout do |oauth_client_row|
        oauth_client_row.with_row(mb: 3) do
          render(Primer::Beta::Text.new(font_weight: :bold)) { I18n.t("wikis.admin.wiki_providers.oauth.xwiki_oauth") }
        end

        oauth_client_row.with_row(mb: 3) do
          render(Primer::Beta::Text.new) { I18n.t("wikis.admin.wiki_providers.oauth.xwiki_oauth_description") }
        end

        oauth_client_row.with_row do
          # hidden field submits the auto-generated client_id (disabled fields are not submitted)
          concat(hidden_field_tag "oauth_client[client_id]", resolved_oauth_client.client_id)
          concat(render(Wikis::Admin::SubmitOrCancelForm.new(form, wiki_provider:,
                                                             cancel_button_options: { href: cancel_button_path })))
        end
      end
    end
  end
%>
