<%=
  component_wrapper do
    primer_form_with(
      model: wiki_provider,
      url: form_url,
      method: form_method
    ) do |form|
      flex_layout do |general_info_row|
        general_info_row.with_row(mb: 3) do
          render(Primer::Beta::Text.new(font_weight: :bold)) { I18n.t("wikis.admin.wiki_providers.xwiki_instance") }
        end

        general_info_row.with_row(mb: 3) do
          render(Primer::Beta::Text.new(test_selector: "wiki-provider-configuration-instructions")) do
            I18n.t("wikis.admin.wiki_providers.xwiki_instance_description_html",
                  app_link: render(Primer::Beta::Link.new(
                    href: "https://extensions.xwiki.org/xwiki/bin/view/Extension/OpenProject%20Integration%20Application/",
                    target: "_blank",
                    underline: true
                  ) { I18n.t("wikis.admin.wiki_providers.xwiki_app_link_text") })
            ).html_safe
          end
        end

        general_info_row.with_row(mb: 3) do
          render(Wikis::Admin::NameInputForm.new(form))
        end

        general_info_row.with_row(mb: 3) do
          render(Wikis::Admin::UrlInputForm.new(form))
        end

        general_info_row.with_row do
          render(Wikis::Admin::SubmitOrCancelForm.new(form, wiki_provider:))
        end
      end
    end
  end
%>
