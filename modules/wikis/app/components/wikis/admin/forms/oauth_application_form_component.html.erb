<%=
  component_wrapper do
    flex_layout(flex_items: :center) do |credentials_row|
      credentials_row.with_row(mb: 3) do
        render(Primer::Beta::Text.new(font_weight: :bold)) { I18n.t("wikis.admin.wiki_providers.oauth.openproject_oauth") }
      end

      credentials_row.with_row(mb: 3) do
        render(Primer::Beta::Text.new) { I18n.t("wikis.admin.wiki_providers.oauth.openproject_oauth_description") }
      end

      credentials_row.with_row(mb: 3) do
        render(Primer::OpenProject::InputGroup.new(input_width: :large)) do |input_group|
          input_group.with_text_input(
            name: :openproject_oauth_application_uid,
            label: I18n.t("wikis.admin.wiki_providers.oauth.application_id"),
            visually_hide_label: false,
            value: oauth_application.uid,
            required: true
          )
          input_group.with_trailing_action_clipboard_copy_button(
            value: oauth_application.uid,
            aria: { label: I18n.t("button_copy_to_clipboard") }
          )
        end
      end

      credentials_row.with_row(mb: 3) do
        render(Primer::OpenProject::InputGroup.new(input_width: :large)) do |input_group|
          input_group.with_text_input(
            name: :openproject_oauth_application_secret,
            label: I18n.t("wikis.admin.wiki_providers.oauth.application_secret"),
            visually_hide_label: false,
            value: oauth_application.plaintext_secret,
            required: true
          )
          input_group.with_trailing_action_clipboard_copy_button(
            value: oauth_application.plaintext_secret,
            aria: { label: I18n.t("button_copy_to_clipboard") }
          )
        end
      end

      credentials_row.with_row do
        render(Primer::Beta::Button.new(
          scheme: :primary,
          tag: :a,
          href: done_button_path
        )) { I18n.t("wikis.buttons.done_continue") }
      end
    end
  end
%>
