<%= render(border_box_container) do |component| %>
  <% component.with_row(scheme: :neutral) do %>
    <%= render(Primer::Beta::Text.new(font_weight: :semibold)) { I18n.t("wikis.admin.wiki_providers.sections.general_information") } %>
  <% end %>

  <% component.with_row(scheme: :default) do %>
    <%= render(Wikis::Admin::Forms::GeneralInfoFormComponent.new(wiki_provider)) %>
  <% end %>

  <% component.with_row(scheme: :neutral) do %>
    <%= render(Primer::Beta::Text.new(font_weight: :semibold, color: :muted)) { I18n.t("wikis.admin.wiki_providers.sections.oauth_applications") } %>
  <% end %>

  <% component.with_row(scheme: :default) do %>
    <%= flex_layout do |row| %>
      <% row.with_row do %>
        <%= render(Primer::Beta::Text.new(font_weight: :bold, color: :muted)) { I18n.t("wikis.admin.wiki_providers.oauth.openproject_oauth") } %>
      <% end %>
      <% row.with_row do %>
        <%= render(Primer::Beta::Text.new(color: :muted)) { I18n.t("wikis.admin.wiki_providers.oauth.openproject_oauth_description") } %>
      <% end %>
    <% end %>
  <% end %>

  <% component.with_row(scheme: :default) do %>
    <%= flex_layout do |row| %>
      <% row.with_row do %>
        <%= render(Primer::Beta::Text.new(font_weight: :bold, color: :muted)) { I18n.t("wikis.admin.wiki_providers.oauth.xwiki_oauth") } %>
      <% end %>
      <% row.with_row do %>
        <%= render(Primer::Beta::Text.new(color: :muted)) { I18n.t("wikis.admin.wiki_providers.oauth.xwiki_oauth_description") } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
