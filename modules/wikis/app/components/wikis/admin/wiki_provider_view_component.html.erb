<%= render(border_box_container) do |component|
      component.with_row(scheme: :neutral) do
        render(Primer::Beta::Text.new(font_weight: :semibold)) { I18n.t("wikis.admin.wiki_providers.sections.basic_details") }
      end

      component.with_row(scheme: :default) do
        if wizard_step == :general_info
          render(Wikis::Admin::Forms::GeneralInfoFormComponent.new(wiki_provider))
        else
          render(Wikis::Admin::GeneralInfoComponent.new(wiki_provider))
        end
      end

      component.with_row(scheme: :neutral, color: :muted) do
        render(Primer::Beta::Text.new(font_weight: :semibold)) { I18n.t("wikis.admin.wiki_providers.sections.oauth_applications") }
      end

      component.with_row(scheme: :default) do
        concat(render(Primer::Beta::Text.new(font_weight: :bold, display: :block)) { I18n.t("wikis.admin.wiki_providers.oauth.openproject_oauth") })
        concat(render(Primer::Beta::Text.new(color: :subtle)) { I18n.t("wikis.admin.wiki_providers.oauth.openproject_oauth_description") })
      end

      component.with_row(scheme: :default) do
        concat(render(Primer::Beta::Text.new(font_weight: :bold, display: :block)) { I18n.t("wikis.admin.wiki_providers.oauth.xwiki_oauth") })
        concat(render(Primer::Beta::Text.new(color: :subtle)) { I18n.t("wikis.admin.wiki_providers.oauth.xwiki_oauth_description") })
      end
    end %>
