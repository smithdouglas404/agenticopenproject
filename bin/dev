#!/usr/bin/env bash

# Foreman/Overmind default the base port to 5000; align local defaults with OpenProject docs.
base_port="${PORT:-3000}"

if command -v overmind &> /dev/null; then
  overmind start -f Procfile.dev -p "$base_port"
elif command -v foreman &> /dev/null; then
  foreman start -f Procfile.dev -p "$base_port"
else
  echo 'Neither overmind, nor foreman is installed, either `gem install overmind` or `gem install foreman`.'
  exit 1
fi
