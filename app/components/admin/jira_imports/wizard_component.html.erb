<%= turbo_frame_tag("jira_import_status") do
  render(border_box_container(
           data: { "jira-import-target": model.status_running? ? 'poll' : "finished" }
         )
  ) do |component|
    component.with_row(scheme: :neutral, color: :muted, align_items: :center) do
      render(Primer::Beta::Text.new(font_weight: :semibold)) {
        I18n.t(:"admin.jiras.run.body.groups.configuration.title")
      }
    end
    component.with_row do
      flex_layout do |box|
        box.with_row do
          render(Primer::Beta::Text.new(font_weight: :semibold)) {
            I18n.t(:"admin.jiras.run.body.sections.fetch_data.title")
          }
        end
        if model.status_equal_or_after?(JiraImport::STATE_FETCHED)
          box.with_row do
            render(Primer::Beta::Text.new(font_size: :small, color: :subtle)) {
              I18n.t(:"admin.jiras.run.body.sections.fetch_data.caption_done")
            }
          end
        end
        if [JiraImport::STATE_INITIAL, JiraImport::STATE_FETCH_ERROR].include?(model.status)
          box.with_row(mb: 3) do
            render(Primer::Beta::Text.new) {
              I18n.t(:"admin.jiras.run.body.sections.fetch_data.description")
            }
          end
          if model.status == JiraImport::STATE_FETCH_ERROR
            box.with_row(mb: 3) do
              render(Primer::Alpha::Banner.new(scheme: :danger, icon: :stop)) {
                model.error || I18n.t('js.error.internal')
              }
            end
          end
          box.with_row(mb: 3) do
            render(Primer::Beta::Button.new(
              scheme: :default,
              tag: :a,
              size: :medium,
              href: continue_admin_jira_jira_import_path(jira_id: model.jira.id, id: model.id, step: 'fetch'),
              data: { turbo_frame: "jira_import_status" }
            )) do |component|
              component.with_leading_visual_icon(icon: :"check-circle")
              I18n.t(:"admin.jiras.run.body.sections.fetch_data.button_fetch")
            end
          end
        elsif model.status == JiraImport::STATE_FETCHING
          box.with_row(mt: 3) do
            render(Primer::Box.new(border: true, border_color: :accent, border_radius: 2, bg: :accent, p: 3)) do
              concat render(Primer::Beta::Spinner.new(size: :small))
              concat render(Primer::Beta::Text.new(ml: 2)) {
                I18n.t(:"admin.jiras.run.body.sections.fetch_data.label_progress")
              }
            end
          end
        end
      end
    end
    component.with_row do
      flex_layout do |box|
        box.with_row do
          render(Primer::Beta::Text.new(font_weight: :semibold)) {
            I18n.t(:"admin.jiras.run.body.sections.import_scope.title")
          }
        end
        if model.status_before?(JiraImport::STATE_FETCHED)
          box.with_row do
            render(Primer::Beta::Text.new(font_size: :small, color: :subtle)) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.caption")
            }
          end
        elsif model.status_equal_or_after?(JiraImport::STATE_IMPORTED)
          box.with_row do
            render(Primer::Beta::Text.new(font_size: :small, color: :subtle)) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.caption_done")
            }
          end
        end
        if model.status == JiraImport::STATE_FETCHED
          box.with_row(mb: 3, mt: 3) do
            render(Primer::Alpha::Banner.new(scheme: :warning, icon: :alert)) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.info")
            }
          end
          box.with_row(mb: 3) do
            flex_layout do |flex|
              flex.with_column(flex: 1, mr: 1) do
                render(Admin::JiraImports::InfoListBoxComponent.new(
                  title: I18n.t(:"admin.jiras.run.body.sections.import_scope.label_available_data"),
                  list: import_stats_available
                ))
              end
              flex.with_column(flex: 1, ml: 1) do
                render(Admin::JiraImports::InfoListBoxComponent.new(
                  title: I18n.t(:"admin.jiras.run.body.sections.import_scope.label_not_available_data"),
                  list: import_stats_unavailable
                ))
              end
            end
          end
          box.with_row(mb: 3) do
            render(Primer::Beta::Button.new(
              scheme: :primary,
              size: :medium,
              tag: :a,
              href: continue_admin_jira_jira_import_path(jira_id: model.jira.id, id: model.id, step: 'configure'),
              data: { turbo_frame: "jira_import_status" }
            )) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.button_continue")
            }
          end
        elsif [JiraImport::STATE_CONFIGURING, JiraImport::STATE_IMPORT_ERROR].include?(model.status)
          box.with_row(mb: 3, mt: 3) do
            render(Primer::Beta::Text.new) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.label_import")
            }
          end
          box.with_row(mb: 3) do
            render(Primer::Alpha::CheckBoxGroup.new) do |component|
              import_settings.each do |item|
                component.check_box(label: item[:label], caption: item[:caption], checked: item[:checked], value: item[:value])
              end
            end
          end
          box.with_row(mb: 3) do
            render(Primer::Beta::Button.new(
              size: :medium,
              tag: :a,
              href: select_projects_modal_admin_jira_jira_import_path(jira_id: model.jira.id, id: model.id),
              data: { controller: "async-dialog" }
            )) {
              "Select projects"
            }
          end
          if model.status == JiraImport::STATE_IMPORT_ERROR
            box.with_row(mb: 3) do
              render(Primer::Alpha::Banner.new(scheme: :danger, icon: :stop)) {
                model.error || I18n.t('js.error.internal')
              }
            end
          end
          box.with_row(mb: 3) do
            render(Primer::Beta::Button.new(
              scheme: :primary,
              size: :medium,
              tag: :a,
              href: continue_admin_jira_jira_import_path(jira_id: model.jira.id, id: model.id, step: 'import'),
              data: { turbo_frame: "jira_import_status" }
            )) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.button_start")
            }
          end
        elsif model.status == JiraImport::STATE_IMPORTING
          box.with_row(mb: 3, mt: 3) do
            render(Primer::Beta::Text.new) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.label_import")
            }
          end
          box.with_row(mb: 3) do
            render(Primer::Box.new(border: true, border_color: :accent, border_radius: 2, bg: :accent, p: 3)) do
              concat render(Primer::Beta::Spinner.new(size: :small))
              concat render(Primer::Beta::Text.new(ml: 2)) {
                I18n.t(:"admin.jiras.run.body.sections.import_scope.label_progress")
              }
            end
          end
          box.with_row(mb: 3) do
            render(Admin::JiraImports::InfoListBoxComponent.new(
              title: I18n.t(:"admin.jiras.run.body.sections.import_scope.label_importing"),
              list: import_settings
            ))
          end
          box.with_row(mb: 3) do
            render(Primer::Beta::Button.new(size: :medium, disabled: true)) {
              I18n.t(:"admin.jiras.run.body.sections.import_scope.button_continue")
            }
          end
        end
      end
    end
    component.with_row(scheme: :neutral, color: :muted, align_items: :center) do
      render(Primer::Beta::Text.new(font_weight: :semibold)) {
        I18n.t(:"admin.jiras.run.body.groups.review.title")
      }
    end
    component.with_row do
      flex_layout do |box|
        box.with_row do
          render(Primer::Beta::Text.new(font_weight: :semibold)) {
            I18n.t(:"admin.jiras.run.body.sections.import_result.title")
          }
        end
        if model.status_before?(JiraImport::STATE_IMPORTED)
          box.with_row do
            render(Primer::Beta::Text.new(font_size: :small, color: :subtle)) {
              I18n.t(:"admin.jiras.run.body.sections.import_result.caption")
            }
          end
        end
        if model.status == JiraImport::STATE_IMPORTED
          box.with_row(mb: 3, mt: 3) do
            render(Primer::Alpha::Banner.new(scheme: :success, icon: :"check-circle")) {
              I18n.t(:"admin.jiras.run.body.sections.import_result.info")
            }
          end
          box.with_row(mb: 3) do
            render(Admin::JiraImports::InfoListBoxComponent.new(
              title: I18n.t(:"admin.jiras.run.body.sections.import_result.label_results"),
              list: import_settings
            ))
          end
        end
        if model.status == JiraImport::STATE_REVERT_ERROR
          box.with_row(mb: 3) do
            render(Primer::Alpha::Banner.new(scheme: :danger, icon: :stop)) {
              model.error || I18n.t('js.error.internal')
            }
          end
        end
        if [JiraImport::STATE_REVERT_ERROR, JiraImport::STATE_IMPORTED].include?(model.status)
          box.with_row(mb: 3) do
            concat(render(Primer::Beta::Button.new(
              scheme: :primary,
              tag: :a,
              size: :medium,
              href: admin_jira_path(model.jira.id)
            )) { I18n.t(:"admin.jiras.run.body.sections.import_result.button_done") })
            concat(render(Primer::Beta::Button.new(
              scheme: :default,
              tag: :a,
              size: :medium,
              href: continue_admin_jira_jira_import_path(jira_id: model.jira.id, id: model.id, step: 'revert'),
              data: { turbo_frame: "jira_import_status" }
            )) { I18n.t(:"admin.jiras.run.body.sections.import_result.button_revert") })
          end
        elsif model.status == JiraImport::STATE_REVERTING
          box.with_row(mb: 3, mt: 3) do
            render(Primer::Box.new(border: true, border_color: :accent, border_radius: 2, bg: :accent, p: 3)) do
              concat render(Primer::Beta::Spinner.new(size: :small))
              concat render(Primer::Beta::Text.new(ml: 2)) {
                I18n.t(:"admin.jiras.run.body.sections.import_result.label_revert_progress")
              }
            end
          end
        elsif model.status == JiraImport::STATE_REVERTED
          box.with_row(mb: 3, mt: 3) do
            render(Primer::Alpha::Banner.new(scheme: :success, icon: :"check-circle")) {
              I18n.t(:"admin.jiras.run.body.sections.import_result.label_reverted")
            }
          end
          box.with_row(mb: 3) do
            render(Primer::Beta::Button.new(
              scheme: :primary,
              tag: :a,
              size: :medium,
              href: admin_jira_path(model.jira.id)
            )) { I18n.t(:"admin.jiras.run.body.sections.import_result.button_done") }
          end
        end
      end
    end
  end
end
%>
