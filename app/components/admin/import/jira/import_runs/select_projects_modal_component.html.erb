<%= render(
      Primer::Alpha::Dialog.new(
        title: I18n.t(:"admin.jira.run.wizard.select_projects.title"),
        id: MODAL_ID,
        size: :xlarge,
        data: { controller: "admin--jira-projects" }
      )
    ) do |d|
  d.with_header(
    show_divider: true,
    variant: :medium
  )
  d.with_body(classes: "Overlay-body_autocomplete_height") do
    render(Admin::Import::Jira::Projects::FormComponent.new(jira_import:))
  end
  d.with_footer(
    show_divider: true
  ) do
    component_collection do |modal_footer|
      modal_footer.with_component(
        Primer::Beta::Button.new(
          data: { "close-dialog-id": MODAL_ID }
        )
      ) do
        I18n.t(:button_cancel)
      end
      modal_footer.with_component(
        Primer::Beta::Button.new(
          scheme: :primary,
          form: Admin::Import::Jira::Projects::FormComponent::FORM_ID,
          type: :submit,
          data: { "admin--jira-projects-target": "counterButton" }
        )
      ) do |button|
        button.with_trailing_visual_counter(
          count: jira_import.projects&.count || 0,
          data: { "admin--jira-projects-target": "counter" }
        )
        I18n.t(:button_continue)
      end
    end
  end
end %>
