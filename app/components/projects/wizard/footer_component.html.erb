<div class="op-projects-wizard-footer">
  <div class="op-projects-wizard-footer--actions-left">
    <% unless first_section? %>
      <%= render(Primer::Beta::Button.new(
        scheme: :invisible,
        color: :muted,
        tag: :a,
        href: project_creation_wizard_path(project, section: previous_section.id)
      )) do |button| %>
        <% button.with_leading_visual_icon(icon: :"arrow-left") %>
        <%= I18n.t("button_back") %>
      <% end %>
    <% end %>
  </div>

  <div class="op-projects-wizard-footer--progress">
    <%=
      flex_layout(justify_content: :center, align_items: :center) do |progress_wrapper|
        progress_wrapper.with_column(classes: "op-projects-wizard-footer--progress-bar") do
          render(Primer::Beta::ProgressBar.new(size: :small)) do |progress_bar|
            progress_bar.with_item(percentage: progress_percentage)
          end
        end

        progress_wrapper.with_column(ml: 2) do
          render(Primer::Beta::Text.new(tag: :div, font_size: :small, color: :muted)) do
            I18n.t("projects.wizard.progress_label", current: current_section_index + 1, total: total_sections)
          end
        end
      end
    %>
  </div>

  <div class="op-projects-wizard-footer--actions-right">
    <%= render(Primer::Beta::Button.new(
      tag: :a,
      href: project_path(project)
    )) do %>
      <%= I18n.t("button_cancel") %>
    <% end %>

    <% if last_section? %>
      <%= render(Primer::Beta::Button.new(
        scheme: :primary,
        type: :submit,
        form: "project-wizard-form",
        name: "finish",
        value: "true"
      )) { I18n.t(:button_complete) } %>
    <% else %>
      <%= render(Primer::Beta::Button.new(
        scheme: :primary,
        type: :submit,
        form: "project-wizard-form",
        name: "next_section",
        value: next_section.id
      )) { I18n.t(:button_continue) } %>
    <% end %>
  </div>
</div>
