<fieldset class="form--fieldset" id="custom-actions-form--actions">
  <legend class="form--fieldset-legend">
    <%= t("custom_actions.actions.name") %>
  </legend>

  <div id="custom-actions-form--active-actions">
    <% custom_action.actions.each do |action| %>
      <%= render partial: "custom_actions/action_section",
                 locals: {
                   action: action
                 } %>
    <% end %>
  </div>

  <div class="form--space"></div>

  <%= render partial: "custom_actions/add_action_select",
             locals: {
               custom_action: custom_action,
               active_section_keys: active_section_keys
             } %>
</fieldset>
