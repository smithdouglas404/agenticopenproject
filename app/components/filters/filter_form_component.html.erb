<% if @wrap_with_controller %>
  <%= tag.div(class: "op-filters-form -expanded", data: controller_data_attributes) do %>
    <%= hidden_filters_input if @hidden_input_name %>
    <%= render(form_list) %>
  <% end %>
<% else %>
  <%= hidden_filters_input if @hidden_input_name %>
  <%= render(form_list) %>
<% end %>
