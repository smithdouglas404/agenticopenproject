<%=
  flex_layout do |flex|
    flex.with_row do
      flex_layout do |header|
        header.with_column do
          render(Primer::Beta::Link.new(href: project_overview_path(@portfolio), font_weight: :bold)) { @portfolio.name }
        end

        # TODO: render status_code

        # TODO: render progress bar
      end
    end

    flex.with_row do
      @portfolio.description
    end

    flex.with_row do
      flex_layout do |footer|
        footer.with_column do
          render(
            Primer::Beta::IconButton.new(
              icon: currently_favorited? ? "star-fill" : "star",
              scheme: :invisible,
              mobile_icon: currently_favorited? ? "star-fill" : "star",
              size: :medium,
              tag: :a,
              tooltip_direction: :e,
              href: helpers.build_favorite_path(@portfolio, format: :html),
              data: { turbo_method: currently_favorited? ? :delete : :post },
              classes: currently_favorited? ? "op-primer--star-icon " : "",
              label: currently_favorited? ? I18n.t(:button_unfavorite) : I18n.t(:button_favorite),
              aria: { label: currently_favorited? ? I18n.t(:button_unfavorite) : I18n.t(:button_favorite) },
              test_selector: "op-portfolios--favorite-button"
            )
          )
        end

        footer.with_column do
          render(
            Primer::Beta::Octicon.new(
              icon: workspace_icon("program"),
              align_self: :center,
              "aria-label": "TODO",
              mr: 1
            )
          ) + content_tag(:span, program_count_label)
        end

        footer.with_column do
          render(
            Primer::Beta::Octicon.new(
              icon: workspace_icon("project"),
              align_self: :center,
              "aria-label": "TODO",
              mr: 1
            )
          ) + content_tag(:span, project_count_label)
        end

        footer.with_column do
          render(
            Primer::Beta::Octicon.new(
              icon: "op-budget",
              align_self: :center,
              "aria-label": "TODO",
              mr: 1
            )
          ) + content_tag(:span, budget_label)
        end

        footer.with_column do
          render(
            Primer::Beta::Text.new(
              color: :muted,
              data: { test_selector: "op-portfolios--updated-at" }
            )
          ) do
            updated_at_label
          end
        end
      end
    end
  end
%>
