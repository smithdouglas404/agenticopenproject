<%= grid_layout("full-view-page-layout", tag: :div, **@system_arguments) do |page| %>
  <% page.with_area("header") do %>
    <%= header %>
  <% end %>

  <% page.with_area("left") do %>
    <% unless mobile? %>
      <%= left_tab %>
    <% end %>
  <% end %>

  <% page.with_area("right") do %>
    <% if right_tab %>
      <%= render Primer::Alpha::UnderlineNav.new(**@nav_arguments) do |nav| %>
        <% rendered_tabs.each do |tab| %>
          <%= render_tab(nav, tab) %>
        <% end %>
      <% end %>

      <div class="full-view-page-layout--right-content">
        <%= right_tab %>
      </div>
    <% end %>
  <% end %>
<% end %>
