<%=
  component_wrapper do
    render(Primer::Beta::BorderBox.new(padding: :condensed)) do |box|
      box.with_row do
        render(
          Primer::Beta::Link.new(href: my_account_path).with_content(t(:label_profile))
        )
      end

      box.with_row do
        render(
          Primer::Beta::Link.new(href: my_page_path).with_content(t(:"my_page.label"))
        )
      end

      box.with_row do
        render(
          Primer::Beta::Link.new(href: my_password_path).with_content(t(:button_change_password))
        )
      end
    end
  end
%>
