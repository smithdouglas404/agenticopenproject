<%= component_wrapper(
      class: "type-form-configuration-page--wrapper",
      data: wrapper_data
    ) do %>
  <%= render(Primer::Alpha::Layout.new(stacking_breakpoint: :md, overflow: :hidden, h: :full, classes: "type-form-configuration-page")) do |content| %>
    <% content.with_sidebar(row_placement: :start, col_placement: :start, border: true, border_bottom: 0, p: 3, overflow: :auto, classes: "type-form-configuration-page--sidebar") do %>
      <%= render(
            WorkPackageTypes::FormConfiguration::InactiveAttributesSidebarComponent.new(
              type: @type,
              inactives: @inactives
            )
          ) %>
    <% end %>

    <% content.with_main(overflow: :auto, classes: "type-form-configuration-page--main") do %>
      <%= render(
            WorkPackageTypes::FormConfiguration::MainContentComponent.new(
              type: @type,
              section_components: section_components,
              ee_available: ee_available?
            )
          ) %>
    <% end %>
  <% end %>

  <%= render(
        Primer::OpenProject::DangerDialog.new(
          id: "type-form-configuration-reset-dialog",
          title: t("js.types.attribute_groups.reset_title"),
          confirm_button_text: t("js.label_reset"),
          form_arguments: {
            action: type_form_configuration_path(@type),
            method: :patch,
            data: { turbo_stream: true }
          }
        )
      ) do |dialog| %>
    <% dialog.with_confirmation_message do |message| %>
      <% message.with_heading(tag: :h2) { t("js.types.attribute_groups.reset_title") } %>
      <% message.with_description_content(t("js.types.attribute_groups.confirm_reset")) %>
    <% end %>

    <% dialog.with_additional_details do %>
      <%= hidden_field_tag("type[attribute_groups]", "[]") %>
    <% end %>
  <% end %>

  <% unless ee_available? %>
    <%= render(
          Primer::OpenProject::FeedbackDialog.new(
            id: enterprise_dialog_id,
            title: t("js.types.attribute_groups.upgrade_to_ee"),
            data: { "test-selector": enterprise_dialog_id }
          )
        ) do |dialog| %>
      <% dialog.with_feedback_message(icon_arguments: { icon: :alert, color: :attention }) do |message| %>
        <% message.with_heading(tag: :h2) { t("js.types.attribute_groups.upgrade_to_ee") } %>
        <% message.with_description_content(t("js.types.attribute_groups.upgrade_to_ee_text")) %>
      <% end %>

      <% dialog.with_footer do %>
        <%= component_collection do |footer| %>
          <% footer.with_component(
               Primer::Beta::Button.new(
                 scheme: :secondary,
                 data: { "close-dialog-id": enterprise_dialog_id }
               )
             ) { t("js.types.attribute_groups.nevermind") } %>

          <% footer.with_component(
               Primer::Beta::Button.new(
                 scheme: :primary,
                 tag: :a,
                 href: enterprise_information_url
               )
             ) { t("js.types.attribute_groups.more_information") } %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
