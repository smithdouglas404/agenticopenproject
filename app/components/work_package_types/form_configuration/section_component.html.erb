<%=
  component_wrapper(
    data: {
      group_type: @group[:type].to_s,
      group_key: @group[:key].to_s,
      group_query: @group[:query],
      edit_mode: (true if edit_mode?)
    }.compact.merge(draggable_item_config)
  ) do
    render(border_box_container(mt: 3, data: row_drop_target_config)) do |box|
      box.with_header(font_weight: :bold) do
        if edit_mode?
          primer_form_with(
            scope: :section,
            method: :patch,
            url: update_path,
            data: { turbo_stream: true }
          ) do
            flex_layout(align_items: :center) do |header|
              header.with_column(flex: 1, mr: 2) do
                render(Primer::Alpha::TextField.new(
                  name: "section[name]",
                  label: t("types.edit.form_configuration.section_name_label"),
                  visually_hide_label: true,
                  value: section_name,
                  autofocus: true,
                  autocomplete: "off",
                  "full-width": true
                ))
              end

              header.with_column(mr: 2) do
                render(Primer::Beta::Button.new(scheme: :primary, type: :submit)) { t("button_save") }
              end

              header.with_column do
                render(
                  Primer::Beta::Button.new(
                    scheme: :secondary,
                    tag: :a,
                    href: cancel_edit_path,
                    data: { turbo_method: :post, turbo_stream: true }
                  )
                ) { t("button_cancel") }
              end
            end
          end
        else
          flex_layout(justify_content: :space_between, align_items: :center) do |header|
            header.with_column(flex_layout: true, align_items: :center, flex: 1) do |left|
              left.with_column(mr: 2, classes: "hide-when-print") do
                render(Primer::OpenProject::DragHandle.new(
                  classes: "section-handle",
                  "aria-label": t("types.edit.form_configuration.drag_to_reorder")
                ))
              end
              left.with_column(flex: 1) do
                render(Primer::Beta::Text.new(font_weight: :bold)) { @group[:name] }
              end
            end

            header.with_column(classes: "hide-when-print") do
              render(Primer::Alpha::ActionMenu.new) do |menu|
                menu.with_show_button(
                  icon: "kebab-horizontal",
                  scheme: :invisible,
                  size: :small,
                  "aria-label": t("types.edit.form_configuration.section_actions")
                )

                menu.with_item(
                  label: t("types.edit.form_configuration.rename_section"),
                  tag: :a,
                  href: edit_path,
                  content_arguments: { data: { turbo_stream: true } }
                ) do |item|
                  item.with_leading_visual_icon(icon: :pencil)
                end

                unless first? && last?
                  menu.with_divider
                end

                unless first?
                  menu.with_item(
                    label: t("label_agenda_item_move_to_top"),
                    tag: :a,
                    href: move_path(:highest),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "move-to-top")
                  end

                  menu.with_item(
                    label: t("label_agenda_item_move_up"),
                    tag: :a,
                    href: move_path(:higher),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "chevron-up")
                  end
                end

                unless last?
                  menu.with_item(
                    label: t("label_agenda_item_move_down"),
                    tag: :a,
                    href: move_path(:lower),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "chevron-down")
                  end

                  menu.with_item(
                    label: t("label_agenda_item_move_to_bottom"),
                    tag: :a,
                    href: move_path(:lowest),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "move-to-bottom")
                  end
                end

                menu.with_divider

                menu.with_item(
                  label: t("button_delete"),
                  scheme: :danger,
                  tag: :a,
                  href: destroy_path,
                  content_arguments: { data: { turbo_method: :delete, turbo_stream: true } }
                ) do |item|
                  item.with_leading_visual_icon(icon: :trash)
                end
              end
            end
          end
        end
      end

      if query_group?
        box.with_row do
          flex_layout(justify_content: :space_between, align_items: :center) do |row|
            row.with_column(flex: 1) do
              render(Primer::Beta::Text.new(color: :subtle)) do
                t("types.edit.form_configuration.query_group_label")
              end
            end

            row.with_column(classes: "hide-when-print") do
              render(Primer::Alpha::ActionMenu.new) do |menu|
                menu.with_show_button(
                  icon: "kebab-horizontal",
                  scheme: :invisible,
                  size: :small,
                  "aria-label": t("types.edit.form_configuration.row_actions")
                )

                menu.with_item(
                  label: t("types.edit.form_configuration.edit_query"),
                  tag: :button,
                  value: "",
                  content_arguments: {
                    data: { action: "click->admin--type-form-configuration#editQuery" }
                  }
                ) do |item|
                  item.with_leading_visual_icon(icon: :pencil)
                end

                unless first? && last?
                  menu.with_divider
                end

                unless first?
                  menu.with_item(
                    label: t("label_agenda_item_move_to_top"),
                    tag: :a,
                    href: move_path(:highest),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "move-to-top")
                  end

                  menu.with_item(
                    label: t("label_agenda_item_move_up"),
                    tag: :a,
                    href: move_path(:higher),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "chevron-up")
                  end
                end

                unless last?
                  menu.with_item(
                    label: t("label_agenda_item_move_down"),
                    tag: :a,
                    href: move_path(:lower),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "chevron-down")
                  end

                  menu.with_item(
                    label: t("label_agenda_item_move_to_bottom"),
                    tag: :a,
                    href: move_path(:lowest),
                    content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: "move-to-bottom")
                  end
                end

                menu.with_divider

                menu.with_item(
                  label: t("button_delete"),
                  scheme: :danger,
                  tag: :a,
                  href: destroy_path,
                  content_arguments: { data: { turbo_method: :delete, turbo_stream: true } }
                ) do |item|
                  item.with_leading_visual_icon(icon: :trash)
                end
              end
            end
          end
        end
      else
        if attributes.empty?
          box.with_row(data: { "empty-list-item": true }) do
            render(Primer::Beta::Text.new(color: :subtle, ml: 2)) do
              t("types.edit.form_configuration.empty_section_hint")
            end
          end
        end

        attributes.each_with_index do |attribute, index|
          box.with_row(
            data: {
              attr_key: attribute[:key],
              attr_translation: attribute[:translation],
              attr_is_cf: attribute[:is_cf],
              "draggable-id": attribute[:key],
              "draggable-type": "attribute",
              "drop-url": row_drop_path(attribute)
            }
          ) do
            flex_layout(justify_content: :space_between, align_items: :center) do |row|
              row.with_column(flex_layout: true, align_items: :center, flex: 1) do |left|
                left.with_column(mr: 2, classes: "hide-when-print") do
                  render(Primer::OpenProject::DragHandle.new(
                    classes: "attribute-handle",
                    "aria-label": t("types.edit.form_configuration.drag_to_reorder")
                  ))
                end
                left.with_column(flex: 1) do
                  render(Primer::Beta::Text.new) { attribute[:translation] }
                end
              end

              row.with_column(classes: "hide-when-print") do
                render(Primer::Alpha::ActionMenu.new) do |menu|
                  menu.with_show_button(
                    icon: "kebab-horizontal",
                    scheme: :invisible,
                    size: :small,
                    "aria-label": t("types.edit.form_configuration.row_actions")
                  )

                  unless index.zero?
                    menu.with_item(
                      label: t("label_agenda_item_move_to_top"),
                      tag: :a,
                      href: row_move_path(attribute, :highest),
                      content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                    ) do |item|
                      item.with_leading_visual_icon(icon: "move-to-top")
                    end

                    menu.with_item(
                      label: t("label_agenda_item_move_up"),
                      tag: :a,
                      href: row_move_path(attribute, :higher),
                      content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                    ) do |item|
                      item.with_leading_visual_icon(icon: "chevron-up")
                    end
                  end

                  unless index == attributes.length - 1
                    menu.with_item(
                      label: t("label_agenda_item_move_down"),
                      tag: :a,
                      href: row_move_path(attribute, :lower),
                      content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                    ) do |item|
                      item.with_leading_visual_icon(icon: "chevron-down")
                    end

                    menu.with_item(
                      label: t("label_agenda_item_move_to_bottom"),
                      tag: :a,
                      href: row_move_path(attribute, :lowest),
                      content_arguments: { data: { turbo_method: :put, turbo_stream: true } }
                    ) do |item|
                      item.with_leading_visual_icon(icon: "move-to-bottom")
                    end
                  end

                  menu.with_divider

                  menu.with_item(
                    label: t("button_delete"),
                    scheme: :danger,
                    tag: :a,
                    href: row_destroy_path(attribute),
                    content_arguments: { data: { turbo_method: :delete, turbo_stream: true } }
                  ) do |item|
                    item.with_leading_visual_icon(icon: :trash)
                  end
                end
              end
            end
          end
        end
      end
    end
  end
%>
