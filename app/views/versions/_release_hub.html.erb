<%
  percent = total_count.zero? ? 0 : (closed_count * 100.0 / total_count).round
  all_url = release_work_packages_path(version)
%>

<%= render(Primer::Beta::BorderBox.new(mb: 3, test_selector: "release-readiness")) do |box| %>
  <% box.with_header(font_weight: :bold) { t(:label_release_readiness) } %>
  <% box.with_row do %>
    <%= render(Primer::Beta::Text.new(font_size: :normal)) do %>
      <%= t(:label_release_readiness_done) %>: <%= "#{closed_count} / #{total_count}" %> (<%= percent %>%)
    <% end %>
  <% end %>
<% end %>

<%= render(Primer::Beta::BorderBox.new(test_selector: "release-work-packages")) do |box| %>
  <% box.with_header(font_weight: :bold) { t(:label_related_work_packages) } %>
  <% if issues.present? %>
    <% issues.each do |issue| %>
      <% box.with_row do %>
        <%= render(::WorkPackages::InfoLineComponent.new(work_package: issue, font_size: :small)) %>
        <%= content_tag(:span, issue.subject, class: "ellipsis") %>
      <% end %>
    <% end %>
    <% if all_url && total_count > issues.size %>
      <% box.with_row do %>
        <%= link_to(t("projects.settings.releases.show_all_work_packages", count: total_count), all_url) %>
      <% end %>
    <% end %>
  <% else %>
    <% box.with_row do %>
      <%= t("projects.settings.releases.no_work_packages") %>
    <% end %>
  <% end %>
<% end %>

<%= render(Primer::Beta::BorderBox.new(mt: 3, test_selector: "release-notes")) do |box| %>
  <% box.with_header(font_weight: :bold) { t("versions.release_notes.title") } %>
  <% box.with_row do %>
    <% if release_notes.any? %>
      <%= render(Primer::Beta::Text.new(tag: :p, color: :muted)) { t("versions.release_notes.hint") } %>
      <%= content_tag(
            :textarea,
            release_notes.to_markdown,
            readonly: true, rows: 12,
            class: "op-input-text",
            style: "width: 100%; font-family: monospace;",
            "aria-label": t("versions.release_notes.title"),
            data: { test_selector: "release-notes-content" }
          ) %>
      <% if version.wiki_page_title.present? && version.project.wiki &&
            authorize_for(:versions, :write_release_notes) &&
            User.current.allowed_in_project?(:edit_wiki_pages, version.project) %>
        <%= render(
              Primer::Beta::Button.new(
                tag: :a, mt: 2, scheme: :default,
                href: write_release_notes_version_path(version),
                data: { turbo_method: :post, turbo_confirm: t(:text_are_you_sure) }
              )
            ) { t("versions.release_notes.write_to_wiki", page: version.wiki_page_title) } %>
      <% end %>
    <% else %>
      <%= t("versions.release_notes.empty") %>
    <% end %>
  <% end %>
<% end %>
