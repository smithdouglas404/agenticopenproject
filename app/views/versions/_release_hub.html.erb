<%
  total = issues.size
  done = issues.count { |issue| issue.status.is_closed? }
  percent = total.zero? ? 0 : (done * 100.0 / total).round
%>

<%= render(Primer::Beta::BorderBox.new(mb: 3, test_selector: "release-readiness")) do |box| %>
  <% box.with_header(font_weight: :bold) { t(:label_release_readiness) } %>
  <% box.with_row do %>
    <%= render(Primer::Beta::Text.new(font_size: :normal)) do %>
      <%= t(:label_release_readiness_done) %>: <%= "#{done} / #{total}" %> (<%= percent %>%)
    <% end %>
  <% end %>
<% end %>

<%= render(Primer::Beta::BorderBox.new(test_selector: "release-work-packages")) do |box| %>
  <% box.with_header(font_weight: :bold) { t(:label_related_work_packages) } %>
  <% if issues.present? %>
    <% issues.each do |issue| %>
      <% box.with_row do %>
        <%= render(::WorkPackages::InfoLineComponent.new(work_package: issue, font_size: :small)) %>
        <%= content_tag(:span, issue.subject, class: "ellipsis") %>
      <% end %>
    <% end %>
  <% else %>
    <% box.with_row do %>
      <%= t("projects.settings.releases.no_work_packages") %>
    <% end %>
  <% end %>
<% end %>
