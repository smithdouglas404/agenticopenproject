<%= tag.section id: "condition_section_#{condition.key}",
                class: "custom-actions-form--condition-section hide-section",
                data: { name: "condition_#{condition.key}" } do %>
  <div class="form--field">
    <%= styled_label_tag("custom_action_conditions_#{condition.key}", condition.human_name, class: "-top") %>
    <% input_name = "custom_action[conditions][#{condition.key}]" %>
    <div class="form--field-container">
      <div class="form--select-container -middle">
        <% case condition.key %>
        <% in :project %>
          <%= angular_component_tag "opce-project-autocompleter",
                                    inputs: {
                                      multiple: true,
                                      filters: [{ name: "active", operator: "=", values: ["t"] }],
                                      resource: "projects",
                                      inputName: input_name,
                                      appendTo: "body",
                                      labelForId: "custom_action_conditions_#{condition.key}",
                                      inputValue: condition.values
                                    } %>
        <% in Symbol => k if k.start_with?("custom_field_") %>
          <div>
            <%= angular_component_tag "opce-autocompleter",
                                      inputs: {
                                        multiple: true,
                                        defaultData: false,
                                        items: condition.allowed_values.map { { id: it[:value], name: it[:label] } },
                                        model: condition.value_objects.map { { id: it[:value], name: it[:label] } },
                                        inputName: input_name,
                                        bindLabel: "name",
                                        labelForId: "custom_action_conditions_#{condition.key}",
                                        appendTo: "body"
                                      } %>
          </div>
        <% else %>
          <%= angular_component_tag "opce-autocompleter",
                                    inputs: {
                                      multiple: true,
                                      defaultData: false,
                                      items: condition.allowed_values.map { { id: it[:value], name: it[:label] } },
                                      model: condition.value_objects.map { { id: it[:value], name: it[:label] } },
                                      inputName: input_name,
                                      bindLabel: "name",
                                      labelForId: "custom_action_conditions_#{condition.key}",
                                      appendTo: "body"
                                    } %>
        <% end %>
      </div>
    </div>
    <%= link_to remove_condition_section_custom_actions_path(key: "condition_#{condition.key}"),
                class: "spot-link",
                title: t(:button_close),
                data: {
                  controller: "admin--custom-action-remove-section",
                  action: "click->admin--custom-action-remove-section#remove"
                } do %>
      <%= op_icon("icon-close icon-small") %>
    <% end %>
  </div>
<% end %>
