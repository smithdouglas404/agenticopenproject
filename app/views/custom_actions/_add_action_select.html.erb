<div id="add-custom-action-select-wrapper"
     class="form--field"
     data-controller="admin--custom-action-add-section"
     data-admin--custom-action-add-section-url-value="<%= action_section_custom_actions_path %>"
     data-admin--custom-action-add-section-container-id-value="custom-actions-form--active-actions"
     data-admin--custom-action-add-section-id-value="<%= custom_action.persisted? ? custom_action.id : '' %>">
  <label class="form--label" for="add-custom-action-select">
    <%= op_icon("icon-add icon4") %>
    <%= I18n.t(:"custom_actions.actions.add") %>
  </label>
  <span class="form--field-container">
    <span class="form--select-container -middle">
      <%= select_tag "add_action",
                     options_for_select(
                       custom_action.all_actions.map { [ it.human_name, "action_#{it.key}" ] },
                       disabled: active_section_keys
                     ),
                     id: "add-custom-action-select",
                     prompt: t(:"custom_actions.actions.add"),
                     class: "form--select",
                     data: {
                       "admin--custom-action-add-section-target": "select",
                       action: "change->admin--custom-action-add-section#add"
                     } %>
    </span>
  </span>
</div>
